---
import { Image } from "astro:assets";
import RandomGirl from "../../assets/random-girl.jpg";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  id="about-section"
  class="flex max-sm:flex-col border-accent-dark border-b-3 max-h-screen"
>
  <!-- Image -->
  <div class="sm:w-5/12 sm:border-r-3 max-sm:border-b-3 border-accent-dark about-img overflow-hidden relative">
    <Image
      src={RandomGirl}
      alt="Brazilian Hair Studio"
      class="w-full h-full object-cover object-center max-sm:hidden"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-linear-to-t from-accent-dark/30 to-transparent pointer-events-none"></div>
  </div>

  <!-- Content -->
  <div class="sm:w-7/12 px-14 py-20 max-sm:px-8 max-sm:py-14 flex flex-col justify-center gap-8 bg-beige-500">
    <div class="about-eyebrow flex items-center gap-4">
      <span class="block w-10 h-px bg-accent-dark opacity-50"></span>
      <span class="text-xs uppercase tracking-[0.2em] text-accent-dark/60 font-sans">Brazilian Hair Studio</span>
    </div>

    <h2 class="about-heading text-4xl max-sm:text-3xl font-serif italic text-accent-dark leading-tight">
      {t("about.heading")}
    </h2>

    <p class="about-text text-beige-700 leading-relaxed text-[0.95rem] max-w-prose">
      {t("about.body")}
    </p>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.from(".about-img", {
    scrollTrigger: {
      trigger: "#about-section",
      start: "top 80%",
    },
    opacity: 0,
    x: -60,
    duration: 1,
    ease: "power3.out",
  });

  gsap.from([".about-eyebrow", ".about-heading", ".about-text"], {
    scrollTrigger: {
      trigger: "#about-section",
      start: "top 75%",
    },
    opacity: 0,
    y: 30,
    duration: 0.8,
    stagger: 0.15,
    ease: "power3.out",
  });
</script>
