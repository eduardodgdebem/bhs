---
import Button from "../ui/Button.astro";
import PageHero from "../ui/PageHero.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const categories = [
  {
    catKey: "cat1",
    services: ["s1", "s2", "s3", "s4", "s5", "s6", "s7", "s8"],
  },
  {
    catKey: "cat2",
    services: ["s9", "s10"],
  },
  {
    catKey: "cat3",
    services: ["s11"],
  },
] as const;

const pullQuote = {
  en: "Ready to transform? Get in touch and book your appointment.",
  pt: "Pronta para se transformar? Entre em contato e agende seu horário.",
  sp: "¿Lista para transformarte? Contáctanos y reserva tu cita.",
}[lang];
---

<PageHero
  id="servicespage-hero"
  bgText="BHS"
  eyebrow="Brazilian Hair Studio · Naples, FL"
  heading={t("servicespage.heading")}
  subtitle={t("servicespage.subtitle")}
/>

<!-- 3 Category sections -->
{
  categories.map(({ catKey, services }, ci) => {
    const catLabel = t(`servicespage.${catKey}` as any) as string;
    const catNum = String(ci + 1).padStart(2, "0");
    const isDark = ci % 2 !== 0;

    return (
      <section class={`svcpage-cat border-b-3 border-accent-dark ${isDark ? "bg-accent-dark" : "bg-beige-500"}`}>
        <div class="flex items-baseline gap-6 px-10 py-8 max-sm:px-8 max-sm:py-6 border-b-3 border-accent-dark">
          <span class={`font-serif italic text-5xl max-sm:text-4xl leading-none ${isDark ? "text-beige-500" : "text-accent-dark"}`}>
            {catLabel}
          </span>
          <span class={`text-xs uppercase tracking-widest ${isDark ? "text-beige-700" : "text-accent-dark/40"}`}>
            {catNum}
          </span>
        </div>

        <div class={`grid grid-cols-3 max-md:grid-cols-2 max-sm:grid-cols-1 gap-px ${isDark ? "bg-beige-500/20" : "bg-accent-dark"}`}>
          {services.map((key) => {
            const title = t(`servicespage.${key}.title` as any) as string;
            const items = t(`servicespage.${key}.items` as any) as string[];

            return (
              <div
                class={`svcpage-card px-8 py-8 flex flex-col gap-3 cursor-default ${isDark ? "bg-accent-dark" : "bg-beige-500"}`}
                data-dark={isDark ? "true" : "false"}
              >
                <h3 class={`text-base font-light tracking-wide uppercase ${isDark ? "text-beige-500" : "text-accent-dark"}`}>
                  {title}
                </h3>
                <p class="text-beige-700 text-sm leading-relaxed">
                  {items.join(" · ")}
                </p>
              </div>
            );
          })}
        </div>
      </section>
    );
  })
}

<!-- CTA -->
<section class="bg-beige-500 px-8 py-24 max-sm:py-16 flex flex-col items-center gap-8 svcpage-cta">
  <p class="font-serif italic text-2xl max-sm:text-xl text-accent-dark text-center max-w-lg leading-snug">
    {pullQuote}
  </p>
  <Button href="tel:+12393188366" variant="dark" size="lg">
    {t("servicespage.cta")}
  </Button>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener("load", () => {
    // Scroll-in: stagger cards per category
    document.querySelectorAll<HTMLElement>(".svcpage-cat").forEach((cat) => {
      gsap.from(cat.querySelectorAll(".svcpage-card"), {
        scrollTrigger: { trigger: cat, start: "top 85%" },
        opacity: 0,
        y: 24,
        duration: 0.6,
        stagger: 0.1,
        ease: "power3.out",
      });
    });

    gsap.from(".svcpage-cta", {
      scrollTrigger: { trigger: ".svcpage-cta", start: "top 95%" },
      opacity: 0,
      scale: 0.97,
      duration: 0.7,
      ease: "power3.out",
    });

    // Hover: lift + brighten
    document.querySelectorAll<HTMLElement>(".svcpage-card").forEach((card) => {
      const isDark = card.dataset.dark === "true";

      card.addEventListener("mouseenter", () => {
        gsap.to(card, {
          y: -6,
          scale: 1.02,
          backgroundColor: isDark ? "#1a5244" : "#f5f3e8",
          duration: 0.25,
          ease: "power2.out",
          overwrite: "auto",
        });
      });

      card.addEventListener("mouseleave", () => {
        gsap.to(card, {
          y: 0,
          scale: 1,
          backgroundColor: isDark ? "#0e3b31" : "#edebdf",
          duration: 0.3,
          ease: "power2.inOut",
          overwrite: "auto",
        });
      });
    });

    ScrollTrigger.refresh();
  });
</script>
