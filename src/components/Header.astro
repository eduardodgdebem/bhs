---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import LogoImg from "../assets/bhs-logo.png";
import LogoSmallImg from "../assets/bhs-logo-small-dark.png";
import Button from "./ui/Button.astro";
import { getLangFromUrl, useTranslations, localePath, switchLangPath } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const langLinks = [
  { code: "en", label: "EN", href: switchLangPath(Astro.url, "en") },
  { code: "pt", label: "PT", href: switchLangPath(Astro.url, "pt") },
  { code: "sp", label: "SP", href: switchLangPath(Astro.url, "sp") },
];

const navLinks = [
  { href: localePath(lang, "/home"), label: t("nav.home") },
  { href: localePath(lang, "/about"), label: t("nav.about") },
  { href: localePath(lang, "/services"), label: t("nav.services") },
  { href: localePath(lang, "/team"), label: t("nav.team") },
  { href: localePath(lang, "/appointment"), label: t("nav.book") },
];
---

<header
  id="site-header"
  class="h-24 flex items-center px-10 text-accent-dark text-xl fixed top-0 left-0 right-0 bg-beige-500 z-50"
>
  <a href="/" class="h-12 flex-none flex gap-4">
    <Image
      src={LogoSmallImg}
      alt="Brazilian Hair Studio"
      class="h-full w-auto object-contain"
      loading="eager"
    />
    <Image
      src={LogoImg}
      alt="Brazilian Hair Studio"
      class="max-sm:hidden h-full w-auto object-contain"
      loading="eager"
    />
  </a>

  <div class="ml-auto flex items-center gap-4">
    <Button href="/appointment" variant="dark" size="sm" icon="material-symbols-light:phone-enabled" class="max-sm:hidden border!">
      {t("nav.book")}
    </Button>

  <button
    id="menu-toggle"
    class="p-2"
    aria-label="Toggle menu"
    aria-expanded="false"
    aria-controls="nav-overlay"
  >
    <div class="relative w-8 h-8">
      <Icon id="icon-menu" name="material-symbols-light:menu" class="w-8 h-8 absolute inset-0" />
      <Icon id="icon-close" name="material-symbols-light:close" class="w-8 h-8 absolute inset-0" />
    </div>
  </button>
  </div>
</header>

<!-- Full-screen nav overlay (sits behind the header) -->
<div
  id="nav-overlay"
  class="fixed inset-0 z-40 pointer-events-none"
  aria-hidden="true"
>
  <div id="nav-bg" class="absolute inset-0 bg-beige-500"></div>

  <div
    class="relative h-full flex flex-col justify-center px-16 max-sm:px-10 pt-24 pb-12"
  >
    <nav class="flex flex-col gap-2">
      {
        navLinks.map((link) => (
          <a href={link.href} class="nav-item group flex items-baseline gap-3">
            <span class="text-accent-dark/30 font-sans text-sm w-6 text-right group-hover:text-accent-dark/60 transition-colors">
              {String(navLinks.indexOf(link) + 1).padStart(2, "0")}
            </span>
            <span class="text-accent-dark font-serif italic leading-none group-hover:text-beige-700 transition-colors" style="font-size: clamp(3rem, 9vw, 4.5rem);">
              {link.label}
            </span>
          </a>
        ))
      }
    </nav>

    <div
      class="nav-item flex items-center gap-3 mt-12 pt-6 border-t border-accent-dark/20 text-sm"
    >
      {
        langLinks.map((l, i) => (
          <>
            {i > 0 && <span class="text-accent-dark/30">|</span>}
            <a
              href={l.href}
              class={
                lang === l.code
                  ? "font-semibold text-accent-dark"
                  : "text-accent-dark/40 hover:text-accent-dark transition-colors"
              }
            >
              {l.label}
            </a>
          </>
        ))
      }
    </div>
  </div>
</div>

<script>
  import { gsap } from "gsap";

  const toggle = document.getElementById("menu-toggle")!;
  const overlay = document.getElementById("nav-overlay")!;
  const navBg = document.getElementById("nav-bg")!;
  const iconMenu = document.getElementById("icon-menu")!;
  const iconClose = document.getElementById("icon-close")!;
  const header = document.getElementById("site-header")!;
  const navItems = gsap.utils.toArray<HTMLElement>(".nav-item");

  let isOpen = false;

  // Initial states
  gsap.set(navBg, { scaleX: 0, transformOrigin: "right" });
  gsap.set(navItems, { opacity: 0, y: 32 });
  gsap.set(iconClose, { opacity: 0, rotate: -45, scale: 0.5 });

  function animateToClose() {
    gsap.killTweensOf([iconMenu, iconClose]);
    gsap.to(iconMenu, { opacity: 0, rotate: 90, scale: 0.5, duration: 0.2, ease: "power2.in" });
    gsap.to(iconClose, { opacity: 1, rotate: 0, scale: 1, duration: 0.25, ease: "back.out(1.5)", delay: 0.1 });
  }

  function animateToMenu() {
    gsap.killTweensOf([iconMenu, iconClose]);
    gsap.to(iconClose, { opacity: 0, rotate: 45, scale: 0.5, duration: 0.2, ease: "power2.in" });
    gsap.to(iconMenu, { opacity: 1, rotate: 0, scale: 1, duration: 0.25, ease: "back.out(1.5)", delay: 0.1 });
  }

  function openMenu() {
    isOpen = true;
    overlay.classList.remove("pointer-events-none");
    overlay.setAttribute("aria-hidden", "false");
    toggle.setAttribute("aria-expanded", "true");
    animateToClose();
    document.body.style.overflow = "hidden";

    gsap.killTweensOf([navBg, ...navItems]);

    gsap
      .timeline()
      .to(navBg, { scaleX: 1, duration: 0.65, ease: "power3.inOut" })
      .to(
        navItems,
        { opacity: 1, y: 0, duration: 0.5, stagger: 0.08, ease: "power3.out" },
        "-=0.25",
      );
  }

  function closeMenu() {
    isOpen = false;
    toggle.setAttribute("aria-expanded", "false");
    animateToMenu();
    document.body.style.overflow = "";

    gsap.killTweensOf([navBg, ...navItems]);

    gsap
      .timeline({
        onComplete: () => {
          overlay.classList.add("pointer-events-none");
          overlay.setAttribute("aria-hidden", "true");
        },
      })
      .to(navItems, {
        opacity: 0,
        y: 20,
        duration: 0.25,
        stagger: { each: 0.04, from: "end" },
        ease: "power2.in",
      })
      .to(
        navBg,
        { scaleX: 0, duration: 0.5, ease: "power3.inOut", transformOrigin: "right" },
        "-=0.1",
      );
  }

  toggle.addEventListener("click", () => (isOpen ? closeMenu() : openMenu()));

  // Hide header on scroll down, show on scroll up
  let lastScroll = 0;
  let hidden = false;

  window.addEventListener("lenis-scroll", (e) => {
    const scroll = (e as CustomEvent).detail.scroll;
    const delta = scroll - lastScroll;
    lastScroll = scroll;

    if (scroll < 80) {
      if (hidden) {
        gsap.to(header, { y: 0, duration: 0.35, ease: "power2.out" });
        hidden = false;
      }
      return;
    }

    if (delta > 0 && !hidden) {
      if (isOpen) closeMenu();
      gsap.to(header, { y: "-100%", duration: 0.35, ease: "power2.in" });
      hidden = true;
    } else if (delta < 0 && hidden) {
      gsap.to(header, { y: 0, duration: 0.35, ease: "power2.out" });
      hidden = false;
    }
  });
</script>
